# ─── PostgreSQL ──────────────────────────────────────────────────────────────
PG_USER=socadmin
PG_PASSWORD=socpassword
PG_DATABASE=secrets_db
PG_HOST=db
PG_PORT=5432

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=5002
JWT_SECRET=change-me-in-production-use-a-long-random-string
NODE_ENV=production

# ─── Frontend ────────────────────────────────────────────────────────────────
# In Docker, the frontend nginx proxies /api → backend, so set to empty or relative
VITE_API_URL=http://localhost:5002
